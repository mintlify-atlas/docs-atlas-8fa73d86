  "keyFeatures": [
    "React-inspired component lifecycle with mounting, updating, and unmounting hooks",
    "Pydux global state management with Pydantic validation and type safety",
    "Reactive widgets that automatically update when state changes",
    "Hybrid application support combining native Qt widgets with modern web UIs",
    "Hot reloading engine for rapid development and instant feedback",
    "Comprehensive CLI for project scaffolding, development, and packaging",
    "Cross-platform packaging with freeze and installer commands",
    "WebEngineBridge for seamless Python-JavaScript communication"
  ],
  "publicApiSurface": [
    "ppg init - Initialize new project",
    "ppg start - Run application in development mode",
    "ppg create - Generate components and views",
    "ppg freeze - Compile to standalone executable",
    "ppg installer - Create platform-specific installer",
    "ppg test - Run unit tests",
    "ppg clean - Clean build artifacts",
    "ApplicationContext - Main application context class",
    "PPGLifeCycle - Component lifecycle mixin",
    "Pydux - Global state management class",
    "@init_lifecycle - Component lifecycle decorator",
    "@hot_reloading - Hot reload decorator",
    "Pydux.set_schema() - Define state schema",
    "Pydux.update_store() - Update global state",
    "Pydux.subscribe_to_store() - Subscribe to state changes",
    "Pydux.update_nested_model() - Update nested Pydantic models",
    "WebEngineBridge - Bridge for web-Python communication",
    "BridgeManager - Manage web engine bridges",
    "ReactiveLabel - Reactive label widget",
    "ReactiveLineEdit - Reactive line edit widget",
    "ReactiveTextEdit - Reactive text edit widget",
    "ReactiveCheckBox - Reactive checkbox widget",
    "ReactiveComboBox - Reactive combo box widget",
    "ReactiveSlider - Reactive slider widget",
    "ReactiveSpinBox - Reactive spin box widget",
    "SETTINGS - Global build settings dictionary",
    "path() - Resolve project paths"
  ]
